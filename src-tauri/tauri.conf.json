{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "CodeGrid",
  "version": "0.1.1",
  "identifier": "dev.codegrid.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Code Grid — Terminal workspace manager",
        "width": 1440,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": true,
        "resizable": true,
        "fullscreen": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../icons/32x32.png",
      "../icons/128x128.png",
      "../icons/128x128@2x.png",
      "../icons/512x512.png",
      "../icons/1024x1024.png",
      "../icons/icon.icns",
      "../icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "frameworks": [],
      "exceptionDomain": "",
      "signingIdentity": "Developer ID Application: ZipLyne LLC (DHGG5BA7J7)",
      "entitlements": "Entitlements.plist",
      "dmg": {
        "background": "../icons/dmg-background.png",
        "windowSize": {
          "width": 660,
          "height": 400
        },
        "appPosition": {
          "x": 200,
          "y": 200
        },
        "applicationFolderPosition": {
          "x": 460,
          "y": 200
        }
      }
    },
    "category": "DeveloperTool",
    "shortDescription": "Code Grid — Terminal workspace manager for multi-session AI coding",
    "longDescription": "Code Grid is a desktop terminal multiplexer that lets you run multiple Claude Code sessions in a free-form 2D grid layout. Features include workspace management, broadcast mode, git manager, MCP server management, and a dense dark theme.",
    "copyright": "Copyright © 2026 Code Grid"
  },
  "plugins": {}
}
